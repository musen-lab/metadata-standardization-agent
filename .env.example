# OpenAI API key for LLM calls (required)
OPENAI_API_KEY=your-openai-api-key

# CEDAR Metadata Center API key for fetching templates (required)
CEDAR_API_KEY=your-cedar-api-key

# BioPortal API key for ontology term lookups (required)
BIOPORTAL_API_KEY=your-bioportal-api-key

# LangSmith tracing (optional — enables observability for LLM calls and agent runs)
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=metadata-migration-agent
